{
  "name": "@kikirrin/livedev-next",
  "version": "0.8.0",
  "description": "Point-and-prompt development overlay for Next.js — click any element, describe a change, create a GitHub issue",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./server": {
      "types": "./dist/server.d.ts",
      "import": "./dist/server.js",
      "require": "./dist/server.cjs"
    },
    "./webpack": "./webpack.cjs",
    "./loader": "./loader.cjs"
  },
  "bin": {
    "livedev": "./dist/cli.js"
  },
  "files": [
    "dist",
    "assets",
    "webpack.cjs",
    "loader.cjs",
    "README.md",
    "INSTALL.md",
    "INSTALL-VENDOR.md"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch"
  },
  "peerDependencies": {
    "next": ">=13",
    "react": ">=18"
  },
  "devDependencies": {
    "@types/node": "^22.9.0",
    "@types/react": "^18.3.12",
    "tsup": "^8.3.5",
    "typescript": "^5.6.3"
  }
}
