{
  "name": "overlay",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "esbuild src/index.ts --bundle --format=esm --outfile=../livedev-next/assets/livedev-overlay.js --target=es2020",
    "dev": "esbuild src/index.ts --bundle --format=esm --outfile=../livedev-next/assets/livedev-overlay.js --target=es2020 --watch",
    "dev:target": "esbuild src/index.ts --bundle --format=esm --outfile=../target-app/public/livedev-overlay.js --target=es2020 --watch"
  },
  "devDependencies": {
    "esbuild": "^0.24.0",
    "typescript": "^5.6.3"
  }
}
