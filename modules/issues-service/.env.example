# GitHub credential the service uses to create issues. Fine-grained PAT scoped to
# the single target repo with "Issues: Read and write" is strongly preferred.
LIVEDEV_GITHUB_PAT=

# Target repository in "owner/repo" form. Server-side only — browser cannot retarget.
LIVEDEV_GITHUB_REPO=owner/repo

# Shared secret between this service and every authorised host-proxy. Rotate per-host
# in production. 32+ bytes of entropy.
LIVEDEV_SERVICE_TOKEN=dev-token

# Comma-separated list of origins allowed to call this service (host-proxy origins).
LIVEDEV_ALLOWED_ORIGINS=http://localhost:3000

# Absolute or relative path to the host's livedev.whitelist.json. If unset, the service
# walks up from its own working directory to find the file.
LIVEDEV_WHITELIST_PATH=../target-app/livedev.whitelist.json

# Optional. Defaults to 8787.
# PORT=8787
