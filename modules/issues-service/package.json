{
  "name": "@livedev/issues-service",
  "version": "0.0.0",
  "private": true,
  "description": "Hono sidecar that holds the GitHub credential and creates issues on behalf of authenticated host-proxy callers.",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "tsx src/index.ts",
    "build": "tsc",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@hono/node-server": "^1.0.0",
    "@livedev/whitelist": "workspace:*",
    "@octokit/rest": "^21.0.0",
    "hono": "^4.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.9.0",
    "tsx": "^4.0.0",
    "typescript": "^5.6.3"
  }
}
