# URL of the livedev issues-service (/issues endpoint).
LIVEDEV_ISSUES_URL=http://localhost:8787/issues

# URL of the livedev issues-service (/prs endpoint) for the /dev dashboard.
LIVEDEV_PRS_URL=http://localhost:8787/prs

# Must match LIVEDEV_SERVICE_TOKEN in modules/issues-service/.env
LIVEDEV_SERVICE_TOKEN=dev-token

# Optional — force overlay to load in production builds.
# NEXT_PUBLIC_LIVEDEV_ENABLED=true
